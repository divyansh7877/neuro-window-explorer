# Ignore everything in public except approved dataset folders/files
apps/nextjs-ui/public/*
!apps/nextjs-ui/public/v*/
!apps/nextjs-ui/public/v*/*
!apps/nextjs-ui/public/datasets.json

# Also include the embeds_chin_2 dataset folder
!apps/nextjs-ui/public/embeds_chin_2/
!apps/nextjs-ui/public/embeds_chin_2/**

# Ignore other large or generated files as needed

# Ignore node_modules everywhere
node_modules/

# Ignore data and versioned artifacts
/v*/
data/
export_code.py
archived_datasets/

# Ignore Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.env

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore Streamlit cache
.streamlit/