# Large dataset files to be tracked with Git LFS
*.npy filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text
*.npz filter=lfs diff=lfs merge=lfs -text
# Large binary files
*.bin filter=lfs diff=lfs merge=lfs -text
*.dat filter=lfs diff=lfs merge=lfs -text
# Track the entire public folder with LFS since it contains large datasets
apps/nextjs-ui/public/ filter=lfs diff=lfs merge=lfs -text
apps/nextjs-ui/public/** filter=lfs diff=lfs merge=lfs -text
# Keep small files as regular git files
*.json -filter=lfs -diff=lfs -merge=lfs -text
*.svg -filter=lfs -diff=lfs -merge=lfs -text
*.tsx -filter=lfs -diff=lfs -merge=lfs -text
*.ts -filter=lfs -diff=lfs -merge=lfs -text
*.js -filter=lfs -diff=lfs -merge=lfs -text
*.jsx -filter=lfs -diff=lfs -merge=lfs -text
*.css -filter=lfs -diff=lfs -merge=lfs -text
*.html -filter=lfs -diff=lfs -merge=lfs -text
*.md -filter=lfs -diff=lfs -merge=lfs -text
*.yml -filter=lfs -diff=lfs -merge=lfs -text
*.yaml -filter=lfs -diff=lfs -merge=lfs -text
*.toml -filter=lfs -diff=lfs -merge=lfs -text
*.lock -filter=lfs -diff=lfs -merge=lfs -text
apps/nextjs-ui/public/**/*.npy filter=lfs diff=lfs merge=lfs -text
apps/nextjs-ui/public/**/*.parquet filter=lfs diff=lfs merge=lfs -text
apps/nextjs-ui/public/**/*.npz filter=lfs diff=lfs merge=lfs -text
